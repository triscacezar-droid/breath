# Supabase (for "others breathing now" presence)
# Get these from: Supabase Dashboard → Project Settings → API (or Connect)
# Project URL: Project Settings → General → "Project URL" or https://<reference-id>.supabase.co
VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
# Use your Publishable key (safe in browser), not the Secret key
VITE_SUPABASE_ANON_KEY=sb_publishable_xxxx

# Zen Chat: set to "true" to enable. Leave unset for production (chat disabled).
# VITE_ZEN_CHAT_ENABLED=true
